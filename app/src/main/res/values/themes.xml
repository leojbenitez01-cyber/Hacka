<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorOnPrimary">@color/bg_deep</item>
        <item name="colorSecondary">@color/accent_lime</item>
        <item name="colorSurface">@color/bg_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_deep</item>  <!-- #4B5563 -->
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
    </style>

    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication" />

    <style name="NavTextActive">
        <item name="android:textSize">9sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textColor">@color/accent_cyan</item>
    </style>

    <style name="NavTextInactive">
        <item name="android:textSize">9sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>
</resources>
