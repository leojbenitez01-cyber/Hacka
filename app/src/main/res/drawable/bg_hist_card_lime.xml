<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0C1420"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item android:width="3dp" android:gravity="start">
        <shape android:shape="rectangle">
            <solid android:color="#39FF14"/>
            <corners android:topLeftRadius="8dp" android:bottomLeftRadius="8dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#1A39FF14"/>
            <corners android:radius="8dp"/>
            <solid android:color="#00000000"/>
        </shape>
    </item>
</layer-list>
