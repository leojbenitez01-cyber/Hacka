<?xml version="1.0" encoding="utf-8"?>
<!--
    ARVoice Maintenance — activity_dashboard.xml
    Pantalla: Dashboard principal (HUD Industrial)
    Colores: bg=#04080F  cyan=#00D4FF  lime=#39FF14  amber=#FFB700
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4B5563">

    <!-- ── STATUS BAR SUPERIOR ────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#080E1A"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <!-- Dot parpadeante -->
        <View
            android:id="@+id/dotLive"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/shape_dot_lime" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="SISTEMA ACTIVO"
            android:textColor="#5A7A9A"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:fontFamily="monospace" />

        <View
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:background="#2A4A6A" />

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_microphone"
            app:tint="#00D4FF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="VOZ ON"
            android:textColor="#5A7A9A"
            android:textSize="10sp"
            android:letterSpacing="0.05"
            android:fontFamily="monospace" />

        <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

    </LinearLayout>

    <!-- ── SCROLL BODY ─────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="60dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- PAGE TAG -->

            <!-- PAGE TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textColor="#E2EAF4"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <!-- PAGE SUBTITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OPERATIVO — COMANDOS DE VOZ ACTIVOS"
                android:textColor="#5A7A9A"
                android:textSize="10sp"
                android:letterSpacing="0.06"
                android:fontFamily="monospace"
                android:layout_marginBottom="16dp" />

            <!-- ── MÉTRICAS 3 COLUMNAS ──────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- Uptime -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_metric_block"
                    android:padding="10dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="98%"
                        android:textColor="#39FF14"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPTIME"
                        android:textColor="#5A7A9A"
                        android:textSize="9sp"
                        android:letterSpacing="0.06"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Equipos -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_metric_block"
                    android:padding="10dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="#00D4FF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EQUIPOS"
                        android:textColor="#5A7A9A"
                        android:textSize="9sp"
                        android:letterSpacing="0.06"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Alertas -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_metric_block"
                    android:padding="10dp"
                    android:layout_marginStart="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textColor="#FFB700"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ALERTAS"
                        android:textColor="#5A7A9A"
                        android:textSize="9sp"
                        android:letterSpacing="0.06"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Línea separadora HUD -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/gradient_hud_line"
                android:layout_marginBottom="14dp" />

            <!-- ── GRID DE ACCIONES 2x2 ────────────────────────── -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="16dp">

                <!-- Escanear Maquinaria -->
                <FrameLayout
                    android:id="@+id/tileScan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_marginEnd="5dp"
                    android:layout_marginBottom="5dp"
                    android:background="@drawable/bg_action_tile_cyan"
                    android:padding="16dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tileBadgeLive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:text="LIVE"
                        android:textColor="#39FF14"
                        android:textSize="9sp"
                        android:letterSpacing="0.06"
                        android:fontFamily="monospace"
                        android:background="@drawable/bg_badge_lime"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_scan"
                            app:tint="#00D4FF"
                            android:layout_marginBottom="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Escanear Maquinaria"
                            android:textColor="#E2EAF4"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="3dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INSPECCIÓN AR"
                            android:textColor="#5A7A9A"
                            android:textSize="10sp"
                            android:letterSpacing="0.06"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Manuales 3D -->
                <FrameLayout
                    android:id="@+id/tileManuals"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginBottom="5dp"
                    android:background="@drawable/bg_action_tile_lime"
                    android:padding="16dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_book"
                            app:tint="#39FF14"
                            android:layout_marginBottom="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manuales 3D"
                            android:textColor="#E2EAF4"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="3dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DOCUMENTACIÓN TÉC."
                            android:textColor="#5A7A9A"
                            android:textSize="10sp"
                            android:letterSpacing="0.06"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Historial -->
                <FrameLayout
                    android:id="@+id/tileHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_marginEnd="5dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_action_tile_amber"
                    android:padding="16dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:text="1 PEND"
                        android:textColor="#FFB700"
                        android:textSize="9sp"
                        android:letterSpacing="0.06"
                        android:fontFamily="monospace"
                        android:background="@drawable/bg_badge_amber"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_history"
                            app:tint="#5A7A9A"
                            android:layout_marginBottom="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Historial"
                            android:textColor="#E2EAF4"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="3dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VER REGISTROS"
                            android:textColor="#5A7A9A"
                            android:textSize="10sp"
                            android:letterSpacing="0.06"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Configuración -->
                <FrameLayout
                    android:id="@+id/tileSettings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_action_tile_default"
                    android:padding="16dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_settings"
                            app:tint="#5A7A9A"
                            android:layout_marginBottom="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Configuración"
                            android:textColor="#E2EAF4"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="3dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AJUSTES DEL SISTEMA"
                            android:textColor="#5A7A9A"
                            android:textSize="10sp"
                            android:letterSpacing="0.06"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                </FrameLayout>
            </GridLayout>

            <!-- ── ACTIVIDAD RECIENTE ──────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVIDAD RECIENTE"
                android:textColor="#5A7A9A"
                android:textSize="9sp"
                android:letterSpacing="0.12"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_hud_box"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <!-- Row A-12 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="A-12"
                        android:textColor="#00D4FF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Compresor Industrial"
                            android:textColor="#E2EAF4"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HACE 2H — PREVENTIVO"
                            android:textColor="#5A7A9A"
                            android:textSize="10sp"
                            android:letterSpacing="0.04"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OK"
                        android:textColor="#39FF14"
                        android:textSize="9sp"
                        android:letterSpacing="0.06"
                        android:fontFamily="monospace"
                        android:background="@drawable/bg_badge_lime"
                        android:paddingStart="7dp"
                        android:paddingEnd="7dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#0C1420" />

                <!-- Row T-08 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="T-08"
                        android:textColor="#00D4FF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Turbina Principal"
                            android:textColor="#E2EAF4"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HACE 5H — CORRECTIVO"
                            android:textColor="#5A7A9A"
                            android:textSize="10sp"
                            android:letterSpacing="0.04"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OK"
                        android:textColor="#39FF14"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:background="@drawable/bg_badge_lime"
                        android:paddingStart="7dp"
                        android:paddingEnd="7dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#0C1420" />

                <!-- Row M-15 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="M-15"
                        android:textColor="#00D4FF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Motor Auxiliar"
                            android:textColor="#E2EAF4"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AYER — PENDIENTE"
                            android:textColor="#5A7A9A"
                            android:textSize="10sp"
                            android:letterSpacing="0.04"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PEND"
                        android:textColor="#FFB700"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:background="@drawable/bg_badge_amber"
                        android:paddingStart="7dp"
                        android:paddingEnd="7dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── BOTTOM NAV ─────────────────────────────────────────── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:background="#080E1A"
        app:itemIconTint="@drawable/nav_item_color"
        app:itemTextColor="@drawable/nav_item_color"
        app:itemTextAppearanceActive="@style/NavTextActive"
        app:itemTextAppearanceInactive="@style/NavTextInactive"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>