<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#04080F">

    <!-- ── BARRA SUPERIOR HUD ──────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@drawable/gradient_top_overlay"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_close_btn"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_close"
                app:tint="#E2EAF4" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="TECLADO DE CONTROL — PANEL A-12"
            android:textColor="#5A7A9A"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:fontFamily="monospace"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_ar_status"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/shape_dot_lime" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="3D ACTIVO"
                android:textColor="#39FF14"
                android:textSize="11sp"
                android:letterSpacing="0.06"
                android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── ETIQUETA DE ZONA ACTIVA ────────────────────────────── -->
    <LinearLayout
        android:id="@+id/zoneLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent">
        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_focus"
            app:tint="#00D4FF" />
        <TextView
            android:id="@+id/tvZone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="ZONA: INSPECCIÓN GENERAL"
            android:textColor="#00D4FF"
            android:textSize="10sp"
            android:letterSpacing="0.06"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- ── VISOR 3D ──────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/modelFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_model_stage"
        app:layout_constraintTop_toBottomOf="@id/zoneLabel"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <io.github.sceneview.ar.ARSceneView
            android:id="@+id/sceneView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Modelo 3D Teclado" />

        <!-- Esquinas HUD -->
        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|start"
            android:background="@drawable/hud_corner_tl" />
        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|end"
            android:background="@drawable/hud_corner_tr" />
        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="bottom|start"
            android:background="@drawable/hud_corner_bl" />
        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/hud_corner_br" />

        <!-- Controles del modelo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:orientation="vertical"
            android:layout_marginEnd="10dp">

            <ImageButton
                android:id="@+id/btnRotate"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_model_ctrl"
                android:src="@drawable/ic_rotate"
                app:tint="#E2EAF4"
                android:layout_marginBottom="6dp"
                android:contentDescription="Rotar" />

            <ImageButton
                android:id="@+id/btnZoomIn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_model_ctrl"
                android:src="@drawable/ic_zoom_in"
                app:tint="#E2EAF4"
                android:layout_marginBottom="6dp"
                android:contentDescription="Acercar" />

            <ImageButton
                android:id="@+id/btnZoomOut"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_model_ctrl"
                android:src="@drawable/ic_zoom_out"
                app:tint="#E2EAF4"
                android:contentDescription="Alejar" />
        </LinearLayout>

        <!-- Loading overlay -->
        <FrameLayout
            android:id="@+id/loadingOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC04080F"
            android:visibility="gone">
            <ProgressBar
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:indeterminateTint="#00D4FF" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="56dp"
                android:text="CARGANDO MODELO..."
                android:textColor="#5A7A9A"
                android:textSize="10sp"
                android:letterSpacing="0.06"
                android:fontFamily="monospace" />
        </FrameLayout>

        <!-- Label inferior -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="8dp"
            android:text="TOCA Y ARRASTRA PARA ROTAR · PELLIZCA PARA ZOOM"
            android:textColor="#5A7A9A"
            android:textSize="9sp"
            android:letterSpacing="0.06"
            android:fontFamily="monospace" />
    </FrameLayout>

    <!-- ── PANEL INFERIOR DE INSTRUCCIONES ───────────────────── -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F74B5563"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Progreso del paso -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvStepNum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASO 01/08"
                android:textColor="#00D4FF"
                android:textSize="11sp"
                android:letterSpacing="0.06"
                android:fontFamily="monospace"
                android:layout_marginEnd="10dp" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:background="#0C1420">
                <View
                    android:id="@+id/stepProgress"
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="#00D4FF" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvStepPct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12%"
                android:textColor="#5A7A9A"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <!-- Instrucción principal -->
        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inspeccione el estado general del teclado de control"
            android:textColor="#E2EAF4"
            android:textSize="17sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="12dp" />

        <!-- Botones ANT / SIG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnPrev"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="ANT"
                android:textColor="#5A7A9A"
                android:textSize="12sp"
                android:letterSpacing="0.05"
                android:fontFamily="monospace"
                app:strokeColor="#2A4A6A"
                app:strokeWidth="1dp"
                android:backgroundTint="#00000000" />

            <Button
                android:id="@+id/btnNext"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="2"
                android:layout_marginStart="6dp"
                android:text="SIGUIENTE"
                android:textColor="#00D4FF"
                android:textSize="12sp"
                android:letterSpacing="0.05"
                android:fontFamily="monospace"
                app:strokeColor="#00D4FF"
                app:strokeWidth="1dp"
                android:backgroundTint="#1A00D4FF" />
        </LinearLayout>

        <!-- Chips de comandos de voz -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='Di "SIGUIENTE"'
                android:textColor="#5A7A9A"
                android:textSize="9sp"
                android:letterSpacing="0.06"
                android:fontFamily="monospace"
                android:background="@drawable/bg_voice_chip"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='Di "REPETIR"'
                android:textColor="#5A7A9A"
                android:textSize="9sp"
                android:letterSpacing="0.06"
                android:fontFamily="monospace"
                android:background="@drawable/bg_voice_chip"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='Di "ZOOM"'
                android:textColor="#5A7A9A"
                android:textSize="9sp"
                android:letterSpacing="0.06"
                android:fontFamily="monospace"
                android:background="@drawable/bg_voice_chip"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="#CC080E1A"
        app:itemIconTint="@drawable/nav_item_color"
        app:itemTextColor="@drawable/nav_item_color"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
